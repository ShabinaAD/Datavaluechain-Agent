# Data Value Chain Agent Foundry — server configuration.
# Everything here is OPTIONAL. The app boots with working defaults when nothing
# is set; unconfigured services degrade gracefully (offline fallback / "Connect
# first") instead of crashing.

# Port the application server listens on.
PORT=8787

# Folder for generated artifacts (not a secret).
DATA_DIR=./data

# --- AI service (kept server-side only; never sent to the browser) ------------
# When AI_API_KEY is empty, the Agent uses deterministic offline fallbacks.
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
# The model name is server-side only and is never exposed to the client or logs.
AI_MODEL=gpt-4o-mini

# --- Database (status only; the client never receives the URL) ----------------
# When empty, source tabs show a non-blocking "Connect first" notice.
DATABASE_URL=
